      - "⚡ 智能测速"

  - name: "🚀 测速工具"
    type: select
    proxies:
      - "🎯 全球直连"
      - "🇭🇰 香港节点"
      - "🇺🇸 美国节点"
      - "🚀 主力代理"

  # —— 地区分组（负载均衡）——
  - name: "🇭🇰 香港节点"
    type: load-balance
    strategy: round-robin
    include-all: true
    filter: '港|HK|Hong\s*Kong|HongKong|hongkong|深港'
    url: https://www.gstatic.com/generate_204
    interval: 250

  - name: "🇺🇸 美国节点"
    type: url-test
    include-all: true
    filter: '美|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|\bUS\b|United\s*States|UnitedStates'
    url: https://www.gstatic.com/generate_204
    interval: 250
    tolerance: 50

  - name: "🇯🇵 日本节点"
    type: load-balance
    strategy: round-robin
    include-all: true
    filter: '日本|川日|东京|大阪|泉日|埼玉|沪日|深日|\bJP\b|Japan'
    url: https://www.gstatic.com/generate_204
    interval: 250

  - name: "🇸🇬 新加坡节点"
    type: load-balance
    strategy: round-robin
    include-all: true
    filter: '新加坡|坡|狮城|\bSG\b|Singapore'
    url: https://www.gstatic.com/generate_204
    interval: 250

  - name: "🇼🇸 台湾节点"
    type: load-balance
    strategy: round-robin
    include-all: true
    filter: '台|新北|彰化|\bTW\b|Taiwan|台灣|臺灣'
    url: https://www.gstatic.com/generate_204
    interval: 250

  - name: "🇰🇷 韩国节点"
    type: load-balance
    strategy: round-robin
    include-all: true
    filter: 'KR|Korea|KOR|首尔|韩|韓'
    url: https://www.gstatic.com/generate_204
    interval: 250

  - name: "🇬🇧 英国节点"
    type: load-balance
    strategy: round-robin
    include-all: true
    filter: '英国|Britain|United\s*Kingdom|England|伦敦'
    url: https://www.gstatic.com/generate_204
    interval: 250

  - name: "🇩🇪 德国节点"
    type: load-balance
    strategy: round-robin
    include-all: true
    filter: '德国|Germany|柏林|法兰克福'
    url: https://www.gstatic.com/generate_204
    interval: 250

  - name: "🌐 其他地区"
    type: select
    include-all: true
    filter: '^(?!.*(港|HK|Hong\s*Kong|美|US|United\s*States|日本|JP|Japan|新加坡|SG|Singapore|台|TW|Taiwan|韩|KR|Korea|英国|Britain|德国|Germany)).*$'

  # —— 固定分组 ——
  - name: "🎯 全球直连"
    type: select
    proxies:
      - DIRECT

  - name: "🔀 非标端口"
    type: select
    proxies:
      - "🎯 全球直连"
      - "🚀 主力代理"

  - name: "🐟 漏网之鱼"
    type: select
    proxies:
      - "🚀 主力代理"
      - "🎯 全球直连"

# ==========================================
# 📜 分流规则（Rules）
# ==========================================
rules:
  # ① 私有网络直连
  - GEOSITE,private,🎯 全球直连
  - GEOIP,private,🎯 全球直连,no-resolve
  - RULE-SET,Custom_Direct_Classical,🎯 全球直连

  # ② ChatGPT / OpenAI（高优先级）
  - DOMAIN,ab.chatgpt.com,🤖 ChatGPT
  - DOMAIN,android.chat.openai.com,🤖 ChatGPT
  - DOMAIN,ios.chat.openai.com,🤖 ChatGPT
  - DOMAIN,chat.openai.com,🤖 ChatGPT
  - DOMAIN,api.openai.com,🤖 ChatGPT
  - DOMAIN,auth.openai.com,🤖 ChatGPT
  - DOMAIN,auth0.openai.com,🤖 ChatGPT
  - DOMAIN,cdn.oaistatic.com,🤖 ChatGPT
  - DOMAIN,chat.openai.com.cdn.cloudflare.net,🤖 ChatGPT
  - DOMAIN-SUFFIX,chatgpt.com,🤖 ChatGPT
  - DOMAIN-SUFFIX,openai.com,🤖 ChatGPT
  - DOMAIN-SUFFIX,oaistatic.com,🤖 ChatGPT
  - DOMAIN-SUFFIX,oaiusercontent.com,🤖 ChatGPT
  - DOMAIN-SUFFIX,openaiapi-site.azureedge.net,🤖 ChatGPT

  # ③ Gemini / Google AI（OAuth 登录）
  - DOMAIN,accounts.google.com,🤖 AI服务
