name: '🚀 自定义分流规则'
desc: |-
  从 Mihomo JS 转换而来的完整分流规则覆写
  包含：AI服务、Apple Intelligence、谷歌服务、社交媒体、游戏、流媒体等分流
  新增：Apple Intelligence / Private Cloud Compute / iCloud Private Relay 分流
  注意：链式代理需要手动配置落地机节点
version: '1.2.0'

# ==========================================
# 📦 远程规则集（Rule Providers）
# ==========================================
rule-providers:
  Custom_Direct_Classical:
    behavior: classical
    format: yaml
    url: https://testingcf.jsdelivr.net/gh/Aethersailor/Custom_OpenClash_Rules@main/rule/Custom_Direct_Classical.yaml
    interval: 28800

  Custom_Proxy_Classical:
    behavior: classical
    format: yaml
    url: https://testingcf.jsdelivr.net/gh/Aethersailor/Custom_OpenClash_Rules@main/rule/Custom_Proxy_Classical.yaml
    interval: 28800

  Steam_CDN_Classical:
    behavior: classical
    format: yaml
    url: https://testingcf.jsdelivr.net/gh/Aethersailor/Custom_OpenClash_Rules@main/rule/Steam_CDN_Classical.yaml
    interval: 2880

  Custom_Port_Direct:
    behavior: classical
    format: yaml
    url: https://testingcf.jsdelivr.net/gh/Aethersailor/Custom_OpenClash_Rules@main/rule/Custom_Port_Direct.yaml
    interval: 28800

# ==========================================
# 🏠 代理节点（落地机）
# ==========================================
# 注意：如需使用链式代理，请在下方添加你的落地机节点
# Stash 不支持 dialer-proxy，链式代理需通过 relay 策略组实现
proxies:
  - name: "🏠 落地机"
    type: socks5
    server: 216.132.151.246
    port: 443
    username: XXLSwBwOWqxJ
    password: yuy3xeYrc3
    tls: false
    skip-cert-verify: true

# ==========================================
# 📋 策略组（Proxy Groups）
# ==========================================
proxy-groups:
  # —— 主力代理（手动选择）——
  - name: "🚀 主力代理"
    type: select
    proxies:
      - "⚡ 智能测速"
      - "🇭🇰 香港节点"
      - "🇺🇸 美国节点"
      - "🇯🇵 日本节点"
      - "🇸🇬 新加坡节点"
      - "🇼🇸 台湾节点"
      - "🇰🇷 韩国节点"
      - "🇬🇧 英国节点"
      - "🇩🇪 德国节点"
      - "🌐 其他地区"

  # —— 智能测速（延迟测速）——
  - name: "⚡ 智能测速"
    type: url-test
    include-all: true
    url: https://www.gstatic.com/generate_204
    interval: 250
    tolerance: 50

  # —— 链式代理（relay 实现）——
  # 流量路径：你 → 美国节点 → 落地机 → 目标
  - name: "🔗 链式代理"
    type: relay
    proxies:
      - "🇺🇸 美国节点"
      - "🏠 落地机"

  # —— AI 服务策略组 ——
  - name: "🤖 ChatGPT"
    type: select
    proxies:
      - "🔗 链式代理"
      - "🇭🇰 香港节点"
      - "🇺🇸 美国节点"
      - "🇯🇵 日本节点"
      - "🇸🇬 新加坡节点"
      - "🌐 其他地区"
      - "🚀 主力代理"
      - "⚡ 智能测速"

  - name: "🤖 Copilot"
    type: select
    proxies:
      - "🔗 链式代理"
      - "🇭🇰 香港节点"
      - "🇺🇸 美国节点"
      - "🇯🇵 日本节点"
      - "🇸🇬 新加坡节点"
      - "🌐 其他地区"
      - "🚀 主力代理"
      - "⚡ 智能测速"

  - name: "🤖 AI服务"
